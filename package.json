{
  "name": "green-diamond",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @green-diamond/frontend dev",
    "build": "pnpm --filter @green-diamond/frontend build",
    "start": "pnpm --filter @green-diamond/frontend start",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "prepare": "node scripts/setup-hooks.mjs",
    "features:backfill": "node scripts/update-features.mjs --backfill",
    "structure:update": "node scripts/update-structure.mjs"
  },
  "devDependencies": {
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "next": "16.2.9",
    "typescript": "^5"
  }
}
