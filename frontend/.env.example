###############################################################################
# Green Diamond — environment reference (.env.example)
#
# Copy to `frontend/.env` (next to this file — Next.js loads env from the
# frontend app dir) and fill in as each phase needs it. Phase 0 runs with NO
# config at all: every provider defaults to "mock". Never commit your real `.env`.
###############################################################################

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3001"

# ── Provider selection (the swappable seam) ──────────────────────────────────
# Keep these on "mock" until the matching real integration is wired up.
PAYMENTS_PROVIDER="mock"        # mock | razorpay   (razorpay = Phase 7)
SHIPPING_PROVIDER="mock"        # mock | shiprocket (shiprocket = Phase 7)
DATA_SOURCE="mock"              # mock | prisma     (prisma = Phase 3)

# ── Commerce config (configurable — NOT hardcoded law) ───────────────────────
GST_RATE_PERCENT="3"            # verify current gems & jewellery GST before go-live
FREE_SHIPPING_THRESHOLD_INR="50000"
FLAT_SHIPPING_RATE_INR="150"

# ── Phase 3: Database (Neon / Supabase / Railway managed Postgres) ───────────
# DATABASE_URL="postgresql://user:password@host:5432/green_diamond?sslmode=require"

# ── Phase 2: Auth.js (NextAuth) ──────────────────────────────────────────────
# AUTH_SECRET="generate with: npx auth secret"
# AUTH_URL="http://localhost:3001"
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ── Phase 6: Email / Media / Monitoring ──────────────────────────────────────
# RESEND_API_KEY=""
# EMAIL_FROM="Green Diamond <orders@greendiamond.in>"
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
# SENTRY_DSN=""

# ── Phase 7 (DEFERRED): Razorpay payments ────────────────────────────────────
# RAZORPAY_KEY_ID=""
# RAZORPAY_KEY_SECRET=""
# RAZORPAY_WEBHOOK_SECRET=""

# ── Phase 7 (DEFERRED): Shiprocket shipping ──────────────────────────────────
# SHIPROCKET_EMAIL=""
# SHIPROCKET_PASSWORD=""
# SHIPROCKET_API_TOKEN=""          # alternative to email/password
# SHIPROCKET_CHANNEL_ID=""
# SHIPROCKET_PICKUP_LOCATION=""
